/var/log/openvpn/koris-*.log {
    daily
    rotate 14
    compress
    delaycompress
    missingok
    notifempty
    create 0640 root root
    postrotate
        systemctl reload openvpn@server 2>/dev/null || \
        systemctl reload openvpn-server@server 2>/dev/null || \
        killall -USR1 openvpn 2>/dev/null || true
    endscript
}
