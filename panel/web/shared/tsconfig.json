{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@koris/types": ["./types"],
      "@koris/types/*": ["./types/*"],
      "@koris/composables": ["./composables"],
      "@koris/composables/*": ["./composables/*"]
    }
  },
  "include": ["**/*.ts", "**/*.vue"]
}
