# KorisPanel Docker Environment Configuration
# Copy this to panel.env and fill in your values

# ─── Database ─────────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=3306
DB_NAME=koris
DB_USER=koris
DB_PASS=change-me-to-random-password
DB_ROOT_PASS=change-me-root-password

# ─── Panel Server ────────────────────────────────────────────────────
PANEL_PORT=2026
PANEL_DOMAIN=panel.example.com
PANEL_SESSION_SECRET=change-me-to-a-random-64-char-string

# ─── Multi-Worker (optional) ─────────────────────────────────────────
# PANEL_WORKERS=2
# PANEL_GRACEFUL_WAIT=30

# ─── Database Pool (optional, auto-tuned by default) ─────────────────
# PANEL_DB_MAX_OPEN=50
# PANEL_DB_MAX_IDLE=25
# PANEL_DB_MAX_LIFETIME=5m

# ─── TUI Dashboard ───────────────────────────────────────────────────
PANEL_TUI_ENABLED=false

# ─── Telegram Bot (optional) ─────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id

# ─── Migrations Path ─────────────────────────────────────────────────
PANEL_MIGRATIONS=/app/migrations
